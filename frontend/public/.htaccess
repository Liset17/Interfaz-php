# =============================================================
# .htaccess del frontend (SPA con Vue Router)
# -------------------------------------------------------------
# Se copia automaticamente a dist/.htaccess al hacer `npm run build`
# (Vite incluye el contenido de /public en el build sin tocar).
#
# Hace falta porque Vue Router usa "history mode" con URLs limpias
# tipo /alumnos, /grupos... Apache no conoce esas rutas y devuelve
# 404 si recargas. La regla de abajo redirige todo lo que NO sea
# un archivo/carpeta existente (y no empiece por /backend) hacia
# index.html, que es donde Vue se encarga del routing.
# =============================================================
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # No tocar las llamadas a la API
  RewriteRule ^backend/ - [L]

  # Si el archivo o carpeta pedida existe, servirla tal cual
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Cualquier otra cosa -> index.html (el router de Vue decide)
  RewriteRule . /index.html [L]
</IfModule>
